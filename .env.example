# assertdrift environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Required for --suggest mode ───────────────────────────────────────────
# Get your free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── Optional overrides ────────────────────────────────────────────────────
# Change the model used for AI suggestions (default: qwen/qwen3.6-plus:free)
# ASSERTDRIFT_MODEL=qwen/qwen3.6-plus:free
